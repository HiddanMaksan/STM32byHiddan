I2C_HandleTypeDef hi2c1;

/* USER CODE BEGIN PV */
#define ADS1115_ADDR  (0x48 << 1)  // 0x90
#define REG_CONVERT   0x00
#define REG_CONFIG    0x01

// ← these are the variables to add in Live Expressions
volatile int16_t  ads_raw     = 0;   // raw 16bit signed value
volatile float    ads_voltage = 0.0f; // converted voltage
volatile uint8_t  ads_ready   = 0;   // 1 = fresh reading
/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
