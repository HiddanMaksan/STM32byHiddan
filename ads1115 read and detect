/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */
void ADS1115_Read(void)
{
    uint8_t config[3];
    uint8_t reg;
    uint8_t data[2];

    // Configure: AIN0 single-ended, ±4.096V, single shot, 128SPS
    config[0] = REG_CONFIG;
    config[1] = 0xC2;  // OS=1, MUX=100(AIN0), PGA=001(4.096V), MODE=1
    config[2] = 0x83;  // DR=100(128SPS), default comparator settings

    HAL_I2C_Master_Transmit(&hi2c1, ADS1115_ADDR, config, 3, 100);

    // Wait for conversion (single shot takes ~8ms at 128SPS)
    HAL_Delay(10);

    // Point to conversion register
    reg = REG_CONVERT;
    HAL_I2C_Master_Transmit(&hi2c1, ADS1115_ADDR, &reg, 1, 100);

    // Read 2 bytes
    HAL_I2C_Master_Receive(&hi2c1, ADS1115_ADDR, data, 2, 100);

    // Store raw value
    ads_raw = (int16_t)((data[0] << 8) | data[1]);

    // Convert to voltage
    // ±4.096V range, 32768 steps
    ads_voltage = ads_raw * 4.096f / 32768.0f;

    ads_ready = 1;
}
/* USER CODE END 0 */

