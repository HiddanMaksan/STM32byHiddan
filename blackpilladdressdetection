int __io_putchar(int ch)
{
    ITM_SendChar(ch);
    return ch;
}

int _write(int file, char *ptr, int len)
{
    for (int i = 0; i < len; i++)
        ITM_SendChar((*ptr++));
    return len;
}

void I2C1_Scan(void)
{
    uint8_t found = 0;

    printf("\r\n=============================\r\n");
    printf("   I2C1 Bus Scanner\r\n");
    printf("   STM32F411 Black Pill\r\n");
    printf("=============================\r\n");
    printf("SCL: PB6  |  SDA: PB7\r\n");
    printf("Scanning 0x08 to 0x77...\r\n\r\n");

    printf("    ");
    for (uint8_t col = 0; col <= 0x0F; col++)
        printf(" %02X", col);
    printf("\r\n");

    for (uint8_t row = 0; row <= 0x07; row++)
    {
        printf("%X0: ", row);
        for (uint8_t col = 0; col <= 0x0F; col++)
        {
            uint8_t addr7 = (row << 4) | col;

            if (addr7 < 0x08 || addr7 > 0x77)
            {
                printf("   ");
                continue;
            }

            if (HAL_I2C_IsDeviceReady(&hi2c1, addr7 << 1, 2, 10) == HAL_OK)
            {
                printf(" %02X", addr7);
                found++;
            }
            else
            {
                printf(" --");
            }
        }
        printf("\r\n");
    }

    printf("\r\n-----------------------------\r\n");

    if (found == 0)
    {
        printf("No devices found!\r\n");
        printf("Check: pull-ups on SDA/SCL? Wiring correct?\r\n");
    }
    else
    {
        printf("Found %d device(s):\r\n\r\n", found);

        for (uint8_t addr7 = 0x08; addr7 <= 0x77; addr7++)
        {
            if (HAL_I2C_IsDeviceReady(&hi2c1, addr7 << 1, 2, 10) == HAL_OK)
            {
                printf("  -> 0x%02X", addr7);
                if      (addr7 >= 0x50 && addr7 <= 0x57) printf("  (EEPROM 24Cxx)");
                else if (addr7 >= 0x48 && addr7 <= 0x4B) printf("  (ADS1115/ADS1015)");
                else if (addr7 == 0x68 || addr7 == 0x69) printf("  (MPU-6050/DS3231)");
                else if (addr7 == 0x3C || addr7 == 0x3D) printf("  (SSD1306 OLED)");
                else if (addr7 == 0x76 || addr7 == 0x77) printf("  (BMP280/BME280)");
                printf("\r\n");
            }
        }
    }

    printf("=============================\r\n\r\n");
}
